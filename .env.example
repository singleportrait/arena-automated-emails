# Are.na API Configuration
# Get your access token from: https://dev.are.na/oauth/applications/new
ARENA_CHANNEL_SLUG=yuppie-dystopia
ARENA_ACCESS_TOKEN=your_arena_access_token_here

# Mailgun Configuration
# Get your API key and domain from: https://app.mailgun.com/
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com
EMAIL_FROM=noreply@yourdomain.com

# Email Recipients
# For multiple recipients, use comma-separated list: email1@example.com,email2@example.com
EMAIL_TO=recipient@example.com
